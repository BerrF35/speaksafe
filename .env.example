# SpeakSafe – Environment Variables
# Copy to .env and fill in values before running

# ── Server ──────────────────────────────────────────────────────
SPEAKSAFE_ENV=development        # development | production
SPEAKSAFE_HOST=0.0.0.0
SPEAKSAFE_PORT=8000

# ── Model ───────────────────────────────────────────────────────
MODEL_PATH=../models/speaksafe_v1.pkl
MAX_AUDIO_SIZE_MB=25

# ── CORS ────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (use * for development)
CORS_ORIGINS=*

# ── API Keys (future auth layer) ────────────────────────────────
# API_SECRET_KEY=your_secret_key_here
# API_RATE_LIMIT=60
